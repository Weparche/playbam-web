# Produkcija / preview build: puni URL API-ja (npr. https://api.vidimose.hr). Obavezno na Cloudflare Pages.
# Lokalni `npm run dev`: ne koristi se — zahtjevi idu na isti origin (/api) i Vite proxy prosljeđuje na :4000 (nema CORS-a).
VITE_API_BASE_URL=https://api.vidimose.hr

# Samo za npm run dev: Bearer za seed hosta (mora se poklapati s PLAYBAM_HOST_AUTH_TOKEN na backendu).
# Ne šalje se dok postoji gost u localStorage (privremena prijava na pozivnici). Ne postavljaj na produkcijskom buildu.
# VITE_DEV_HOST_AUTH_TOKEN=vidimose-dev-host-token
